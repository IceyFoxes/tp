<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <GridPane HBox.hgrow="ALWAYS">
    <columnConstraints>
      <ColumnConstraints hgrow="ALWAYS" minWidth="0.0" />    
    </columnConstraints>
    <VBox alignment="CENTER_LEFT" minHeight="70" spacing="3" GridPane.columnIndex="0" minWidth="0">
      <padding>
          <Insets top="5" right="5" bottom="5" left="15" />
      </padding>
      <HBox spacing="0.5" alignment="CENTER_LEFT" minWidth="0">
          <Label fx:id="id" styleClass="cell_big_label">
              <minWidth>
                  <Region fx:constant="USE_PREF_SIZE" />
              </minWidth>
          </Label>
          <Label fx:id="name" text="\$first" styleClass="cell_big_label" 
                 wrapText="true" maxWidth="Infinity" minWidth="0" HBox.hgrow="ALWAYS" />
      </HBox>
      <FlowPane fx:id="tags" />
      <Label fx:id="phone" styleClass="cell_small_label" text="\$phone" wrapText="true" minWidth="0" />
    </VBox>
  </GridPane>
</HBox>